// clmad.lo.u64 d,a,b,c  (spec PTX ISA 9.3 §9.7.1.5): d = low64(clmul(a,b)) XOR c
.version 9.3
.target sm_121a
.address_size 64
.visible .entry clmad_bug(.param .u64 po, .param .u64 pa, .param .u64 pb, .param .u64 pc)
{
    .reg .b64 rd<8>;
    ld.param.u64 rd5, [po];
    ld.param.u64 rd1, [pa];
    ld.param.u64 rd2, [pb];
    ld.param.u64 rd3, [pc];
    clmad.lo.u64 rd0, rd1, rd2, rd3;
    st.global.u64 [rd5], rd0;
    ret;
}
